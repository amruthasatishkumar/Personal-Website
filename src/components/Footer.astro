---
import { site, nav } from "@/data/site";
const year = new Date().getFullYear();
---

<footer class="mx-auto mt-24 max-w-5xl px-4 pb-12">
  <div class="glass rounded-3xl p-8 sm:p-10">
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <div class="max-w-md">
        <h2 class="font-display text-2xl font-bold">Let's build something trusted.</h2>
        <p class="mt-2 text-[var(--text-muted)]">
          Open to conversations about data platforms, AI, and governance.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/contact" class="btn-primary">Get in touch</a>
        <a href={site.linkedin} target="_blank" rel="noopener" class="btn-ghost">LinkedIn</a>
      </div>
    </div>

    <div class="mt-8 flex flex-col gap-3 border-t border-[var(--border-soft)] pt-6 text-sm text-[var(--text-faint)] sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {site.name}. All rights reserved.</p>
      <div class="flex flex-wrap gap-5">
        {nav.map((item) => (
          <a href={item.href} class="hover:text-[var(--text)]">{item.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
