---
import { nav } from "@/data/site";
import ThemeToggle from "./ThemeToggle.tsx";

const path = Astro.url.pathname;
function isActive(href: string) {
  if (href === "/") return path === "/";
  if (href.startsWith("/#")) return false;
  return path.startsWith(href);
}
---

<header class="sticky top-0 z-50 px-4 pt-4">
  <nav class="glass mx-auto flex max-w-5xl items-center justify-between gap-4 rounded-full px-5 py-3">
    <a href="/" class="font-display text-base font-bold tracking-tight">
      Amrutha<span class="text-gradient">.</span>
    </a>

    <ul class="hidden items-center gap-1 md:flex">
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              "rounded-full px-3 py-1.5 text-sm transition hover:text-[var(--text)]",
              isActive(item.href) ? "text-[var(--text)]" : "text-[var(--text-muted)]",
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <ThemeToggle client:load />
      <button
        type="button"
        id="nav-toggle"
        class="glass grid h-10 w-10 place-items-center rounded-full md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="glass mx-auto mt-2 hidden max-w-5xl rounded-2xl p-3 md:hidden">
    <ul class="flex flex-col gap-1">
      {nav.map((item) => (
        <li>
          <a href={item.href} class="block rounded-xl px-4 py-2 text-sm text-[var(--text-muted)] hover:bg-[var(--glass-bg)] hover:text-[var(--text)]">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(open === false));
  });
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => menu.classList.add("hidden"))
  );
</script>
