---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  site,
  principles,
  certifications,
  education,
} from "@/data/site";
---

<BaseLayout
  title="About"
  description="Amrutha Satishkumar is a Data & AI Solution Engineer at Microsoft focused on AI-ready data platforms, governance, and responsible AI."
>
  <section class="mx-auto max-w-3xl px-4 pt-16 sm:pt-24">
    <div class="reveal">
      <p class="eyebrow">About</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold tracking-tight sm:text-5xl">
        Hi, I'm <span class="text-gradient">Amrutha</span>.
      </h1>
    </div>

    <div class="reveal mt-8 flex flex-col gap-5 text-lg leading-relaxed text-[var(--text-muted)]">
      <p>
        I'm a {site.role} at {site.company}, based in {site.location}, working at the intersection of data and AI. I build the platforms that make AI possible and the agentic systems that run on top of them.
      </p>
      <p>
        Over 7+ years I've grown from deep learning and NLP research into production data engineering and enterprise AI. Along the way I've shipped pipelines that cut training time, models that sharpened forecasting, and AI agents that removed manual work outright, always with an eye on what actually holds up once it leaves the lab.
      </p>
      <p>
        Today I partner with enterprise, education, and ISV customers to modernize their data estates and adopt AI responsibly. Much of that work happens in the room: architecture deep-dives, technical presentations, and live demos that turn ideas into something teams can build on. I care most about solutions that survive past the demo: secure, scalable, governed, and genuinely useful to the people who depend on them.
      </p>
    </div>

    <div class="reveal mt-8 flex flex-wrap gap-3">
      <a href="/contact" class="btn-primary">Get in touch</a>
      <a href="/experience" class="btn-ghost">My experience</a>
      <a href={site.linkedin} target="_blank" rel="noopener" class="btn-ghost">LinkedIn</a>
    </div>
  </section>

  {/* PRINCIPLES */}
  <section class="mx-auto mt-20 max-w-3xl px-4">
    <h2 class="reveal font-display text-2xl font-bold tracking-tight">What I care about</h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-2">
      {principles.map((p) => (
        <div class="glass reveal rounded-2xl p-6 transition hover:-translate-y-1">
          <h3 class="font-display text-base font-bold">{p.title}</h3>
          <p class="mt-2 text-sm text-[var(--text-muted)]">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  {/* EDUCATION + CERTS */}
  <section class="mx-auto mt-20 max-w-3xl px-4">
    <div class="grid gap-5 sm:grid-cols-2">
      <div class="glass reveal rounded-2xl p-6 transition hover:-translate-y-1">
        <h2 class="font-display text-lg font-bold">Education</h2>
        <ul class="mt-4 space-y-3">
          {education.map((e) => (
            <li>
              <p class="font-semibold">{e.degree}</p>
              <p class="text-sm text-[var(--text-muted)]">{e.school}</p>
              <p class="text-sm text-[var(--text-faint)]">{e.years}</p>
            </li>
          ))}
        </ul>
      </div>
      <div class="glass reveal rounded-2xl p-6 transition hover:-translate-y-1">
        <h2 class="font-display text-lg font-bold">Certifications</h2>
        <ul class="mt-4 space-y-3">
          {certifications.map((c) => (
            <li>
              <p class="font-semibold">{c.name}</p>
              <p class="text-sm text-[var(--text-faint)]">{c.issuer}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
