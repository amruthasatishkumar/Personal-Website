---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" noindex={true}>
  <section class="mx-auto grid min-h-[60vh] max-w-3xl place-items-center px-4 text-center">
    <div>
      <p class="font-display text-7xl font-extrabold text-gradient">404</p>
      <h1 class="mt-4 font-display text-2xl font-bold">This page wandered off.</h1>
      <p class="mt-3 text-[var(--text-muted)]">The link may be broken or the page may have moved.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-primary">Back home</a>
        <a href="/blog" class="btn-ghost">Read my blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
