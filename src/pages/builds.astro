---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/data/site";
---

<BaseLayout
  title="Builds"
  description="Live projects and experiments by Amrutha Satishkumar: data labs, web apps, and things built to explore ideas in the open."
>
  <section class="mx-auto max-w-5xl px-4 pt-16 sm:pt-24">
    <div class="reveal">
      <p class="eyebrow">Builds</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold tracking-tight sm:text-5xl">
        Things I've <span class="text-gradient">built</span>.
      </h1>
      <p class="mt-4 max-w-2xl text-base text-[var(--text-muted)]">
        Only a small slice of my work, not a complete portfolio. Most of what I build lives inside customer and enterprise projects I can't show here. These are the ones I can share openly, and each is live, so go ahead and explore.
      </p>
    </div>
  </section>

  <section class="mx-auto mt-12 max-w-5xl px-4">
    <div class="grid gap-5 sm:grid-cols-2">
      {projects.map((p) => (
        <a
          href={p.url}
          target="_blank"
          rel="noopener"
          class="glass reveal group flex flex-col rounded-2xl p-6 transition hover:-translate-y-1"
        >
          <p class="text-xs uppercase tracking-wide text-[var(--text-faint)]">{p.category}</p>
          <h2 class="mt-2 font-display text-xl font-bold">{p.title}</h2>
          <p class="mt-3 flex-1 text-sm text-[var(--text-muted)]">{p.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {p.tags.map((t) => <span class="chip">{t}</span>)}
          </div>
          {p.note && (
            <p class="mt-4 text-xs italic text-[var(--text-faint)]">{p.note}</p>
          )}
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--accent)]">
            Try it out
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="transition group-hover:translate-x-0.5"
            >
              <path d="M7 17 17 7" />
              <path d="M7 7h10v10" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
