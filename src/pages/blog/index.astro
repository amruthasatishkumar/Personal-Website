---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [...new Set(posts.map((p) => p.data.category))].sort();

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const [featured, ...rest] = posts;
---

<BaseLayout
  title="Blog"
  description="Articles on data platforms, Microsoft Fabric, AI, transformers, and governance by Amrutha Satishkumar."
>
  <section class="mx-auto max-w-5xl px-4 pt-16 sm:pt-24">
    <div class="reveal">
      <p class="eyebrow">Blog</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold tracking-tight sm:text-5xl">
        Field notes from <span class="text-gradient">building with data and AI</span>
      </h1>
    </div>

    <div class="mt-8 flex flex-wrap gap-2" data-filter-bar>
      <button class="chip is-active" data-filter="all" type="button">All</button>
      {categories.map((c) => (
        <button class="chip" data-filter={c} type="button">{c}</button>
      ))}
    </div>
  </section>

  {featured && (
    <section class="mx-auto mt-12 max-w-5xl px-4">
      <a
        href={`/blog/${featured.id}`}
        class="glass reveal group grid overflow-hidden rounded-3xl md:grid-cols-2"
        data-category={featured.data.category}
      >
        {featured.data.cover && (
          <div class="aspect-[16/10] overflow-hidden md:aspect-auto">
            <img src={featured.data.cover} alt={featured.data.title} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
          </div>
        )}
        <div class="flex flex-col justify-center p-7 sm:p-9">
          <p class="text-xs uppercase tracking-wide text-[var(--text-faint)]">
            Featured · {featured.data.category} · {featured.data.readTime}
          </p>
          <h2 class="mt-3 font-display text-2xl font-bold leading-snug">{featured.data.title}</h2>
          <p class="mt-3 text-[var(--text-muted)]">{featured.data.description}</p>
          <p class="mt-5 text-sm text-[var(--text-faint)]">{fmt(featured.data.pubDate)}</p>
        </div>
      </a>
    </section>
  )}

  <section class="mx-auto mt-10 max-w-5xl px-4">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-post-grid>
      {rest.map((p) => (
        <a
          href={`/blog/${p.id}`}
          class="glass reveal group flex flex-col overflow-hidden rounded-2xl transition hover:-translate-y-1"
          data-category={p.data.category}
        >
          {p.data.cover && (
            <div class="aspect-[16/10] overflow-hidden">
              <img src={p.data.cover} alt={p.data.title} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
            </div>
          )}
          <div class="flex flex-1 flex-col p-5">
            <p class="text-xs uppercase tracking-wide text-[var(--text-faint)]">{p.data.category} · {p.data.readTime}</p>
            <h3 class="mt-2 font-display text-base font-bold leading-snug">{p.data.title}</h3>
            <p class="mt-2 line-clamp-3 text-sm text-[var(--text-muted)]">{p.data.description}</p>
            <p class="mt-auto pt-4 text-xs text-[var(--text-faint)]">{fmt(p.data.pubDate)}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
    const featuredCard = document.querySelector<HTMLElement>("[data-category]");
    const cards = document.querySelectorAll<HTMLElement>("[data-post-grid] [data-category]");
    buttons.forEach((btn) =>
      btn.addEventListener("click", () => {
        const f = btn.dataset.filter;
        buttons.forEach((b) => b.classList.toggle("is-active", b === btn));
        const show = (el: HTMLElement | null) => {
          if (!el) return;
          const match = f === "all" || el.dataset.category === f;
          el.style.display = match ? "" : "none";
        };
        cards.forEach(show);
        if (featuredCard && featuredCard.closest("section")) {
          const match = f === "all" || featuredCard.dataset.category === f;
          (featuredCard.closest("section") as HTMLElement).style.display = match ? "" : "none";
        }
      })
    );
  </script>
</BaseLayout>
