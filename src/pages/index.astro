---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  site,
  quickFacts,
  focusCards,
  stats,
  skillGroups,
} from "@/data/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<BaseLayout>
  {/* HERO */}
  <section class="mx-auto max-w-5xl px-4 pt-16 sm:pt-24">
    <div class="reveal">
      <p class="eyebrow">{site.role} at {site.company}</p>
      <h1 class="mt-4 font-display text-4xl font-extrabold leading-[1.05] tracking-tight sm:text-6xl">
        I build the <span class="text-gradient">data platforms and AI systems</span> behind reliable, governed, real-world solutions.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-[var(--text-muted)]">
        {site.tagline}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="btn-primary">Get in touch</a>
        <a href="/builds" class="btn-ghost">View my builds</a>
        <a href="/blog" class="btn-ghost">Read my blog</a>
      </div>
      <div class="mt-8 flex flex-wrap gap-2">
        {quickFacts.map((f) => <span class="chip">{f}</span>)}
      </div>
    </div>
  </section>

  {/* STATS */}
  <section class="mx-auto mt-20 max-w-5xl px-4">
    <div class="glass reveal grid grid-cols-2 gap-6 rounded-3xl p-8 sm:grid-cols-4 sm:p-10">
      {stats.map((s) => (
        <div>
          <p class="font-display text-3xl font-extrabold text-gradient sm:text-4xl">{s.value}</p>
          <p class="mt-1 text-sm text-[var(--text-muted)]">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  {/* FOCUS */}
  <section class="mx-auto mt-24 max-w-5xl px-4">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {focusCards.map((c) => (
        <div class="glass reveal rounded-2xl p-6 transition hover:-translate-y-1">
          <h3 class="font-display text-lg font-bold">{c.title}</h3>
          <p class="mt-2 text-sm text-[var(--text-muted)]">{c.body}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ABOUT TEASER */}
  <section class="mx-auto mt-24 max-w-5xl px-4">
    <div class="glass reveal grid gap-8 rounded-3xl p-8 sm:p-10 md:grid-cols-[1.4fr_1fr]">
      <div>
        <p class="eyebrow">About</p>
        <p class="mt-4 text-lg leading-relaxed text-[var(--text)]">
          I work at the intersection of data and AI. Strong AI takes more than good models: it needs solid data foundations, sound architecture, and real governance. I build across all of it, from pipelines and platforms to AI and intelligent agents.
        </p>
        <p class="mt-4 text-[var(--text-muted)]">
          With 7+ years across data engineering, AI, and agentic systems, I design solutions that survive past the demo: secure, scalable, and built to last.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/about" class="inline-flex btn-ghost">More about me</a>
          <a href="/experience" class="inline-flex btn-ghost">See my experience</a>
        </div>
      </div>
      <div class="flex flex-col justify-center gap-4">
        <div class="glass-strong rounded-2xl p-5">
          <p class="text-sm text-[var(--text-faint)]">Based in</p>
          <p class="mt-1 font-display font-semibold">{site.location}</p>
        </div>
        <div class="glass-strong rounded-2xl p-5">
          <p class="text-sm text-[var(--text-faint)]">Currently</p>
          <p class="mt-1 font-display font-semibold">{site.role} @ {site.company}</p>
        </div>
      </div>
    </div>
  </section>

  {/* SKILLS PREVIEW */}
  <section class="mx-auto mt-24 max-w-5xl px-4">
    <div class="reveal flex items-end justify-between">
      <div>
        <p class="eyebrow">Capabilities</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight">What I work with</h2>
      </div>
      <a href="/experience" class="btn-ghost hidden sm:inline-flex">Full breakdown</a>
    </div>
    <div class="mt-10 grid items-stretch gap-5 sm:grid-cols-2">
      {skillGroups.map((g) => (
        <div class="glass reveal rounded-2xl p-6 transition hover:-translate-y-1">
          <h3 class="font-display text-base font-bold">{g.title}</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {g.skills.slice(0, 5).map((s) => <span class="chip">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* LATEST BLOG */}
  {posts.length > 0 && (
    <section class="mx-auto mt-24 max-w-5xl px-4">
      <div class="reveal flex items-end justify-between">
        <div>
          <p class="eyebrow">Blog</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight">Latest articles</h2>
        </div>
        <a href="/blog" class="btn-ghost hidden sm:inline-flex">View all</a>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {posts.map((p) => (
          <a href={`/blog/${p.id}`} class="glass reveal group flex flex-col overflow-hidden rounded-2xl transition hover:-translate-y-1">
            {p.data.cover && (
              <div class="aspect-[16/10] overflow-hidden">
                <img src={p.data.cover} alt={p.data.title} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
              </div>
            )}
            <div class="flex flex-1 flex-col p-5">
              <p class="text-xs uppercase tracking-wide text-[var(--text-faint)]">{p.data.category} · {p.data.readTime}</p>
              <h3 class="mt-2 font-display text-base font-bold leading-snug">{p.data.title}</h3>
              <p class="mt-2 line-clamp-2 text-sm text-[var(--text-muted)]">{p.data.description}</p>
              <p class="mt-auto pt-4 text-xs text-[var(--text-faint)]">{fmt(p.data.pubDate)}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
