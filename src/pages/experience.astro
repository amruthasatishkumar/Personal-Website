---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  stats,
  experience,
  impact,
  skillGroups,
  certifications,
  education,
} from "@/data/site";
---

<BaseLayout
  title="Experience"
  description="The career, impact, and capabilities of Amrutha Satishkumar. 7+ years across data engineering, AI, and agentic systems, now a Data & AI Solution Engineer at Microsoft."
>
  {/* INTRO */}
  <section class="mx-auto max-w-5xl px-4 pt-16 sm:pt-24">
    <div class="reveal">
      <p class="eyebrow">Experience</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold tracking-tight sm:text-5xl">
        A track record of shipping <span class="text-gradient">data & AI</span>.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-[var(--text-muted)]">
        7+ years spanning data engineering, applied AI, and agentic systems. I partner with enterprise, education, and ISV customers to take solutions from first conversation all the way to production, with governance and trust built in from the start.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="btn-primary">Get in touch</a>
        <a href="/blog" class="btn-ghost">Read my blog</a>
      </div>
    </div>
  </section>

  {/* STATS */}
  <section class="mx-auto mt-16 max-w-5xl px-4">
    <div class="glass reveal grid grid-cols-2 gap-6 rounded-3xl p-8 sm:grid-cols-4 sm:p-10">
      {stats.map((s) => (
        <div>
          <p class="font-display text-3xl font-extrabold text-gradient sm:text-4xl">{s.value}</p>
          <p class="mt-1 text-sm text-[var(--text-muted)]">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  {/* IMPACT */}
  <section class="mx-auto mt-24 max-w-5xl px-4">
    <div class="reveal">
      <p class="eyebrow">Selected impact</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight">Outcomes, not just outputs</h2>
    </div>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {impact.map((i) => (
        <div class="glass reveal rounded-2xl p-6">
          <p class="font-display text-4xl font-extrabold text-gradient">{i.metric}</p>
          <p class="mt-1 font-semibold">{i.label}</p>
          <p class="mt-1 text-sm text-[var(--text-muted)]">{i.detail}</p>
        </div>
      ))}
    </div>
  </section>

  {/* TIMELINE */}
  <section class="mx-auto mt-24 max-w-5xl px-4">
    <div class="reveal">
      <p class="eyebrow">Career</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight">Where I've worked</h2>
    </div>
    <ol class="mt-10 space-y-4">
      {experience.map((job) => (
        <li class="glass reveal rounded-2xl p-6 sm:p-7">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <h3 class="font-display text-lg font-bold">
              {job.role} <span class="text-[var(--text-muted)]">· {job.company}</span>
            </h3>
            <p class="text-sm text-[var(--text-faint)] whitespace-nowrap">
              {job.start} to {job.end}
            </p>
          </div>
          <p class="mt-1 text-xs uppercase tracking-wide text-[var(--text-faint)]">{job.location}</p>
          <p class="mt-3 text-[var(--text-muted)]">{job.summary}</p>
          {job.highlights && (
            <ul class="mt-3 grid gap-1.5 text-sm text-[var(--text-muted)] sm:grid-cols-2">
              {job.highlights.map((h) => (
                <li class="flex gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--accent)]"></span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}
          {job.stack && (
            <div class="mt-4 flex flex-wrap gap-2">
              {job.stack.map((s) => <span class="chip">{s}</span>)}
            </div>
          )}
        </li>
      ))}
    </ol>
  </section>

  {/* SKILLS */}
  <section class="mx-auto mt-24 max-w-5xl px-4">
    <div class="reveal">
      <p class="eyebrow">Capabilities</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight">What I work with</h2>
    </div>
    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {skillGroups.map((g) => (
        <div class="glass reveal rounded-2xl p-6">
          <h3 class="font-display text-lg font-bold">{g.title}</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {g.skills.map((s) => <span class="chip">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* CERTIFICATIONS + EDUCATION */}
  <section class="mx-auto mt-24 max-w-5xl px-4">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="glass reveal rounded-2xl p-6">
        <p class="eyebrow">Certifications</p>
        <ul class="mt-4 space-y-3">
          {certifications.map((c) => (
            <li>
              <p class="font-semibold">{c.name}</p>
              <p class="text-sm text-[var(--text-faint)]">{c.issuer}</p>
            </li>
          ))}
        </ul>
      </div>
      <div class="glass reveal rounded-2xl p-6">
        <p class="eyebrow">Education</p>
        <ul class="mt-4 space-y-3">
          {education.map((e) => (
            <li>
              <p class="font-semibold">{e.degree}</p>
              <p class="text-sm text-[var(--text-muted)]">{e.school}</p>
              <p class="text-sm text-[var(--text-faint)]">{e.years}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
