---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="Contact"
  description="Get in touch with Amrutha Satishkumar about data platforms, AI, and governance."
>
  <section class="mx-auto max-w-5xl px-4 pt-16 sm:pt-24">
    <div class="reveal">
      <p class="eyebrow">Contact</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold tracking-tight sm:text-5xl">
        Let's <span class="text-gradient">talk</span>.
      </h1>
      <p class="mt-4 max-w-xl text-lg text-[var(--text-muted)]">
        Whether it's data platforms, AI strategy, governance, or just a good conversation, I'd love to hear from you.
      </p>
    </div>

    <div class="reveal mt-10">
      <a href={site.linkedin} target="_blank" rel="noopener" class="glass flex items-center gap-4 rounded-2xl p-5 transition hover:-translate-y-1">
        <span class="grid h-11 w-11 place-items-center rounded-xl bg-[var(--glass-bg)]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
        </span>
        <span>
          <span class="block font-semibold">LinkedIn</span>
          <span class="block text-sm text-[var(--text-muted)]">Connect with me</span>
        </span>
      </a>
    </div>

    <form id="contact-form" class="glass reveal mt-6 rounded-3xl p-6 sm:p-8">
      <input type="hidden" name="access_key" value={site.web3formsKey} />
      <input type="hidden" name="subject" value="New message from your portfolio site" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium">Name</span>
          <input name="name" required type="text" class="form-input" placeholder="Your name" />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Email</span>
          <input name="email" required type="email" class="form-input" placeholder="you@example.com" />
        </label>
      </div>
      <label class="mt-5 block">
        <span class="text-sm font-medium">Message</span>
        <textarea name="message" required rows="5" class="form-input" placeholder="What's on your mind?"></textarea>
      </label>

      <div class="mt-6 flex items-center gap-4">
        <button type="submit" class="btn-primary">Send message</button>
        <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
      </div>
    </form>
  </section>

  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const status = document.getElementById("form-status");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!status) return;
      const data = new FormData(form);
      const key = data.get("access_key");
      if (!key || key === "YOUR_WEB3FORMS_ACCESS_KEY") {
        status.textContent = "Form not configured yet. Please reach out on LinkedIn instead.";
        status.style.color = "var(--text-muted)";
        return;
      }
      status.textContent = "Sending...";
      status.style.color = "var(--text-muted)";
      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { Accept: "application/json" },
          body: data,
        });
        const json = await res.json();
        if (json.success) {
          status.textContent = "Thanks! I'll get back to you soon.";
          status.style.color = "var(--accent)";
          form.reset();
        } else {
          status.textContent = "Something went wrong. Please reach out on LinkedIn instead.";
          status.style.color = "#ff6b6b";
        }
      } catch {
        status.textContent = "Something went wrong. Please email me instead.";
        status.style.color = "#ff6b6b";
      }
    });
  </script>
</BaseLayout>
